rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public booking site: anyone can read/write bookings
    match /tenants/{tenantId}/bookings/{bookingId} {
      allow read, write: if true;
    }
    // Public booking site needs to list active barbers.
    match /tenants/{tenantId}/barbers/{barberId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Everything else (clients, settings, etc.) requires admin login
    match /tenants/{tenantId}/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
